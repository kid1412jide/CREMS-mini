<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.crems.crems.mapper.CremsInterviewMapper">

    <resultMap type="CremsInterview" id="CremsInterviewResult">
        <result property="interviewId"       column="interview_id"       />
        <result property="applicationId"     column="application_id"     />
        <result property="jobId"             column="job_id"             />
        <result property="studentId"         column="student_id"         />
        <result property="companyId"         column="company_id"         />
        <result property="jobTitle"          column="job_title"          />
        <result property="companyName"       column="company_name"       />
        <result property="studentName"       column="student_name"       />
        <result property="interviewType"     column="interview_type"     />
        <result property="interviewMethod"   column="interview_method"   />
        <result property="interviewTime"     column="interview_time"     />
        <result property="interviewAddress"  column="interview_address"  />
        <result property="interviewer"       column="interviewer"        />
        <result property="contactPhone"      column="contact_phone"      />
        <result property="interviewNotice"   column="interview_notice"   />
        <result property="interviewResult"   column="interview_result"   />
        <result property="interviewFeedback" column="interview_feedback" />
        <result property="score"             column="score"              />
        <result property="status"            column="status"             />
        <result property="createBy"          column="create_by"          />
        <result property="createTime"        column="create_time"        />
        <result property="updateBy"          column="update_by"          />
        <result property="updateTime"        column="update_time"        />
        <result property="remark"            column="remark"             />
    </resultMap>

    <sql id="selectInterviewVo">
        <!-- 面试列表带出职位、企业、学生名称，供学生端和企业端共用展示。 -->
        select i.interview_id, i.application_id, i.job_id, i.student_id, i.company_id,
               j.job_title, c.company_name, s.student_name,
               i.interview_type, i.interview_method, i.interview_time, i.interview_address,
               i.interviewer, i.contact_phone, i.interview_notice, i.interview_result,
               i.interview_feedback, i.score, i.status, i.create_by, i.create_time,
               i.update_by, i.update_time, i.remark
        from crems_interview i
        left join crems_job j on i.job_id = j.job_id
        left join crems_company c on i.company_id = c.company_id
        left join crems_student s on i.student_id = s.student_id
    </sql>

    <select id="selectInterviewById" parameterType="Long" resultMap="CremsInterviewResult">
        <include refid="selectInterviewVo"/>
        where i.interview_id = #{interviewId}
    </select>

    <select id="selectInterviewList" parameterType="CremsInterview" resultMap="CremsInterviewResult">
        <include refid="selectInterviewVo"/>
        <where>
            <if test="applicationId != null">
                AND i.application_id = #{applicationId}
            </if>
            <if test="studentId != null">
                AND i.student_id = #{studentId}
            </if>
            <if test="companyId != null">
                AND i.company_id = #{companyId}
            </if>
            <if test="interviewType != null and interviewType != ''">
                AND i.interview_type = #{interviewType}
            </if>
            <if test="status != null and status != ''">
                AND i.status = #{status}
            </if>
            <if test="studentName != null and studentName != ''">
                AND s.student_name like concat('%', #{studentName}, '%')
            </if>
            <if test="jobTitle != null and jobTitle != ''">
                AND j.job_title like concat('%', #{jobTitle}, '%')
            </if>
        </where>
        order by i.interview_time desc
    </select>

    <insert id="insertInterview" parameterType="CremsInterview" useGeneratedKeys="true" keyProperty="interviewId">
        insert into crems_interview
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="applicationId != null">application_id,</if>
            <if test="jobId != null">job_id,</if>
            <if test="studentId != null">student_id,</if>
            <if test="companyId != null">company_id,</if>
            <if test="interviewType != null">interview_type,</if>
            <if test="interviewMethod != null">interview_method,</if>
            <if test="interviewTime != null">interview_time,</if>
            <if test="interviewAddress != null">interview_address,</if>
            <if test="interviewer != null">interviewer,</if>
            <if test="contactPhone != null">contact_phone,</if>
            <if test="interviewNotice != null">interview_notice,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="applicationId != null">#{applicationId},</if>
            <if test="jobId != null">#{jobId},</if>
            <if test="studentId != null">#{studentId},</if>
            <if test="companyId != null">#{companyId},</if>
            <if test="interviewType != null">#{interviewType},</if>
            <if test="interviewMethod != null">#{interviewMethod},</if>
            <if test="interviewTime != null">#{interviewTime},</if>
            <if test="interviewAddress != null">#{interviewAddress},</if>
            <if test="interviewer != null">#{interviewer},</if>
            <if test="contactPhone != null">#{contactPhone},</if>
            <if test="interviewNotice != null">#{interviewNotice},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateInterview" parameterType="CremsInterview">
        update crems_interview
        <trim prefix="SET" suffixOverrides=",">
            <if test="interviewType != null">interview_type = #{interviewType},</if>
            <if test="interviewMethod != null">interview_method = #{interviewMethod},</if>
            <if test="interviewTime != null">interview_time = #{interviewTime},</if>
            <if test="interviewAddress != null">interview_address = #{interviewAddress},</if>
            <if test="interviewer != null">interviewer = #{interviewer},</if>
            <if test="contactPhone != null">contact_phone = #{contactPhone},</if>
            <if test="interviewNotice != null">interview_notice = #{interviewNotice},</if>
            <if test="interviewResult != null">interview_result = #{interviewResult},</if>
            <if test="interviewFeedback != null">interview_feedback = #{interviewFeedback},</if>
            <if test="score != null">score = #{score},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where interview_id = #{interviewId}
    </update>

    <delete id="deleteInterviewById" parameterType="Long">
        delete from crems_interview where interview_id = #{interviewId}
    </delete>

    <delete id="deleteInterviewByIds" parameterType="Long">
        delete from crems_interview where interview_id in
        <foreach item="interviewId" collection="array" open="(" separator="," close=")">
            #{interviewId}
        </foreach>
    </delete>

</mapper>
