<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.crems.crems.mapper.CremsStudentMapper">

    <resultMap type="CremsStudent" id="CremsStudentResult">
        <result property="studentId"        column="student_id"        />
        <result property="userId"           column="user_id"           />
        <result property="studentNo"        column="student_no"        />
        <result property="studentName"      column="student_name"      />
        <result property="gender"           column="gender"            />
        <result property="birthDate"        column="birth_date"        />
        <result property="phone"            column="phone"             />
        <result property="email"            column="email"             />
        <result property="idCard"           column="id_card"           />
        <result property="school"           column="school"            />
        <result property="major"            column="major"             />
        <result property="education"        column="education"         />
        <result property="grade"            column="grade"             />
        <result property="graduationDate"   column="graduation_date"   />
        <result property="avatarUrl"        column="avatar_url"        />
        <result property="resumeUrl"        column="resume_url"        />
        <result property="selfIntroduction" column="self_introduction" />
        <result property="skills"           column="skills"            />
        <result property="status"           column="status"            />
        <result property="createBy"         column="create_by"         />
        <result property="createTime"       column="create_time"       />
        <result property="updateBy"         column="update_by"         />
        <result property="updateTime"       column="update_time"       />
        <result property="remark"           column="remark"            />
    </resultMap>

    <sql id="selectStudentVo">
        select student_id, user_id, student_no, student_name, gender, birth_date, phone, email,
               id_card, school, major, education, grade, graduation_date, avatar_url,
               resume_url, self_introduction, skills, status, create_by, create_time,
               update_by, update_time, remark
        from crems_student
    </sql>

    <select id="selectStudentById" parameterType="Long" resultMap="CremsStudentResult">
        <include refid="selectStudentVo"/>
        where student_id = #{studentId}
    </select>

    <select id="selectStudentByUserId" parameterType="Long" resultMap="CremsStudentResult">
        <include refid="selectStudentVo"/>
        where user_id = #{userId}
    </select>

    <select id="selectStudentList" parameterType="CremsStudent" resultMap="CremsStudentResult">
        <include refid="selectStudentVo"/>
        <where>
            <if test="studentId != null">
                AND student_id = #{studentId}
            </if>
            <if test="studentNo != null and studentNo != ''">
                AND student_no = #{studentNo}
            </if>
            <if test="studentName != null and studentName != ''">
                AND student_name like concat('%', #{studentName}, '%')
            </if>
            <if test="school != null and school != ''">
                AND school like concat('%', #{school}, '%')
            </if>
            <if test="major != null and major != ''">
                AND major like concat('%', #{major}, '%')
            </if>
            <if test="education != null and education != ''">
                AND education = #{education}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by student_id desc
    </select>

    <insert id="insertStudent" parameterType="CremsStudent" useGeneratedKeys="true" keyProperty="studentId">
        insert into crems_student
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="studentNo != null and studentNo != ''">student_no,</if>
            <if test="studentName != null and studentName != ''">student_name,</if>
            <if test="gender != null">gender,</if>
            <if test="birthDate != null">birth_date,</if>
            <if test="phone != null">phone,</if>
            <if test="email != null">email,</if>
            <if test="idCard != null">id_card,</if>
            <if test="school != null">school,</if>
            <if test="major != null">major,</if>
            <if test="education != null">education,</if>
            <if test="grade != null">grade,</if>
            <if test="graduationDate != null">graduation_date,</if>
            <if test="avatarUrl != null">avatar_url,</if>
            <if test="resumeUrl != null">resume_url,</if>
            <if test="selfIntroduction != null">self_introduction,</if>
            <if test="skills != null">skills,</if>
            <if test="status != null">status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="remark != null">remark,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="studentNo != null and studentNo != ''">#{studentNo},</if>
            <if test="studentName != null and studentName != ''">#{studentName},</if>
            <if test="gender != null">#{gender},</if>
            <if test="birthDate != null">#{birthDate},</if>
            <if test="phone != null">#{phone},</if>
            <if test="email != null">#{email},</if>
            <if test="idCard != null">#{idCard},</if>
            <if test="school != null">#{school},</if>
            <if test="major != null">#{major},</if>
            <if test="education != null">#{education},</if>
            <if test="grade != null">#{grade},</if>
            <if test="graduationDate != null">#{graduationDate},</if>
            <if test="avatarUrl != null">#{avatarUrl},</if>
            <if test="resumeUrl != null">#{resumeUrl},</if>
            <if test="selfIntroduction != null">#{selfIntroduction},</if>
            <if test="skills != null">#{skills},</if>
            <if test="status != null">#{status},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="remark != null">#{remark},</if>
            sysdate()
        </trim>
    </insert>

    <update id="updateStudent" parameterType="CremsStudent">
        update crems_student
        <trim prefix="SET" suffixOverrides=",">
            <if test="studentNo != null and studentNo != ''">student_no = #{studentNo},</if>
            <if test="studentName != null and studentName != ''">student_name = #{studentName},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="birthDate != null">birth_date = #{birthDate},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="email != null">email = #{email},</if>
            <if test="idCard != null">id_card = #{idCard},</if>
            <if test="school != null">school = #{school},</if>
            <if test="major != null">major = #{major},</if>
            <if test="education != null">education = #{education},</if>
            <if test="grade != null">grade = #{grade},</if>
            <if test="graduationDate != null">graduation_date = #{graduationDate},</if>
            <if test="avatarUrl != null">avatar_url = #{avatarUrl},</if>
            <if test="resumeUrl != null">resume_url = #{resumeUrl},</if>
            <if test="selfIntroduction != null">self_introduction = #{selfIntroduction},</if>
            <if test="skills != null">skills = #{skills},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </trim>
        where student_id = #{studentId}
    </update>

    <delete id="deleteStudentById" parameterType="Long">
        delete from crems_student where student_id = #{studentId}
    </delete>

    <delete id="deleteStudentByIds" parameterType="Long">
        delete from crems_student where student_id in
        <foreach item="studentId" collection="array" open="(" separator="," close=")">
            #{studentId}
        </foreach>
    </delete>

</mapper>
